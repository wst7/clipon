{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagAnnotation": "Release v${version}",
    "push": true,
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "draft": false,
    "preRelease": false,
    "autoGenerate": true
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    },
    "@release-it/bumper": {
      "in": "package.json",
      "out": [
        "package.json",
        "src-tauri/Cargo.toml",
        "src-tauri/tauri.conf.json"
      ]
    }
  }
}
